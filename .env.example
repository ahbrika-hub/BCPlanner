# TSS Planner — environment contract (placeholders only; NEVER commit real values).
# Copy to `.env.local` for local development and fill with real values there.
# `.env.local` is gitignored. Supabase wiring lands in P2.

# Supabase (public — safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role (SERVER-ONLY — must never be exposed to the client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Application environment label: development | staging | production
NEXT_PUBLIC_APP_ENV=development

# Transactional email (Resend) — feature-flagged; OFF unless EMAIL_ENABLED=true
# and both RESEND_API_KEY + EMAIL_FROM are set. Server-only.
EMAIL_ENABLED=false
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=no-reply@example.com

# Cron secret (server-only). Vercel Cron sends this as a Bearer token to the
# cron routes: /api/cron/generate-recurring and /api/cron/generate-overdue-digest
# (the daily overdue-escalation digest; sends only when EMAIL_ENABLED is on).
CRON_SECRET=your-random-cron-secret

# Live notification bell via Supabase Realtime (public — safe in the browser).
# OFF unless set to 'true'. Enabling ALSO requires adding public.notifications to
# the `supabase_realtime` publication in the Supabase dashboard (a manual op).
# When false/unset, or if the subscription fails, the bell falls back to the
# existing refresh-on-navigate behavior.
NEXT_PUBLIC_REALTIME_ENABLED=false
